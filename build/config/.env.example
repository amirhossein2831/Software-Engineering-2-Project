# Copy to .env before `docker compose up`. Every value has a safe dev default,
# so an empty .env still boots the whole stack.

# Postgres (single instance, database-per-service)
POSTGRES_USER=ticketing
POSTGRES_PASSWORD=ticketing
POSTGRES_DB=ticketing

# Shared secrets — the same value MUST be used by the services that share it.
JWT_SECRET=dev-only-change-me                 # auth issues, gateway verifies
ADMISSION_SECRET=dev-admission-secret         # waiting-room signs, gateway verifies
TICKET_SIGNING_KEY=dev-ticket-key             # ticketing QR HMAC

# Token lifetimes
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=720h

# Booking behavior
HOLD_TTL_SECONDS=30           # how long a seat hold lives
SWEEP_INTERVAL_SECONDS=5      # how often expired holds are reclaimed
PAYMENT_FAIL_RATE=0           # 0..1 — mock payment failure rate (fault injection)
ADMIT_RATE_PER_SEC=5          # waiting-room drain rate
ADMISSION_TTL_SECONDS=300
ADMISSION_ENFORCED=false      # true = require a waiting-room token on booking

# Gateway
RATE_LIMIT=120                # requests per window per client IP
RATE_WINDOW_SECONDS=60
ALLOWED_ORIGIN=*

# Edge
EDGE_PORT=8090                # nginx host port — open http://localhost:8090
                              # (kept off 80 so it doesn't clash with GitLab)
MAILHOG_PORT=8025             # Mailhog web UI — change if 8025 is taken

LOG_LEVEL=info
