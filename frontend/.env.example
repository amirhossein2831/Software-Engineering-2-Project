# Behind the nginx edge (docker compose), leave these UNSET — the client defaults
# to a relative "/api" origin and derives the WebSocket URL from the page host.
#
# For standalone `npm run dev` (frontend on :3000 hitting the gateway directly),
# set them to the gateway (CORS is enabled on the gateway):
# NEXT_PUBLIC_API_URL=http://localhost:8080
# NEXT_PUBLIC_WS_URL=ws://localhost:8080
